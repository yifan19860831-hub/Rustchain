# Telegram Bot 配置示例

# 从 @BotFather 获取的 Bot Token
# 获取方式：
# 1. 在 Telegram 搜索 @BotFather
# 2. 发送 /newbot 命令
# 3. 按提示设置名称和用户名
# 4. 复制返回的 Token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# RustChain RPC 节点地址
# 如果默认节点不可用，请替换为其他节点
# 可以尝试：
# - https://rpc.rustchain.io
# - https://rustchain.publicnode.com
# - 或自建的私有节点
RUSTCHAIN_RPC_URL=https://rpc.rustchain.io

# 要监控的钱包地址
WATCHED_WALLET=RTC4325af95d26d59c3ef025963656d22af638bb96b

# 交易确认检查间隔（毫秒）
# 建议不低于 30000（30 秒），避免触发 API 限流
CHECK_INTERVAL=30000

# 允许接收通知的聊天 ID（可选）
# 留空则允许所有聊天，建议配置以限制访问
# 获取方式：
# 1. 启动机器人后，在 Telegram 发送 /start
# 2. 访问：https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 3. 在返回的 JSON 中找到 "chat":{"id":123456789}
# 多个 ID 用逗号分隔，例如：123456789,-987654321
ALLOWED_CHAT_IDS=

# 日志级别
# 可选值：error, warn, info, debug
# 生产环境建议使用 info 或 error
LOG_LEVEL=info
